{
  "name": "alexa-agent",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" && turbo run lint typecheck test build",
    "lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" && turbo run lint",
    "lint:docs": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "markdownlint-cli2": "0.23.0",
    "turbo": "2.10.4"
  }
}
